{
  "os_type": "webOS",
  "report_template": "output/reports/template/template.xlsm",
  "output_dir": "output/reports",

  "impedance": "6R",
  "rated_power_w": 10.0,
  "power_tolerance_percent": 10,
  "thd_n_max_percent": 10,
  "lr_imbalance_db": 0.5,

  "snr": {
    "speaker_target_power_w": 0.5,
    "speaker_threshold_db": 60,
    "speaker_row": 59,
    "headphone_target_vrms_mv": 100,
    "headphone_threshold_db": 55,
    "headphone_row": 8,
    "volume_search_min": 1,
    "volume_search_max": 100,
    "volume_search_max_iters": 14,
    "power_relative_tolerance": 0.05,
    "noise_settle_s": 3.0
  },

  "speaker_index": {
    "freq_response_row": 63,
    "crosstalk_row": 65,
    "phase_row": 66,
    "freq_sweep_start_hz": 20,
    "freq_sweep_stop_hz": 20000,
    "freq_sweep_points": 100,
    "crosstalk_freq_hz": 1000,
    "signal_level_vrms": 0.5,
    "crosstalk_threshold_db": 50,
    "phase_max_deg": 10,
    "freq_response_low_limit_hz": 100,
    "freq_response_high_limit_hz": 15000
  },

  "switch_channel_wait_s": 5.0,
  "signal_play_wait_s": 10.0,
  "volume_settle_s": 2.0,

  "headphone": {
    "target_vrms_mv_min": 130,
    "target_vrms_mv_max": 150,
    "thd_n_max_percent": 10
  },

  "routing": {
    "DTV-DVB": "DTVPlayer",
